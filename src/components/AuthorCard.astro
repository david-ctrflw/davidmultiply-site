---
import PortraitCarousel from './PortraitCarousel.astro';
---

<section class="mt-20">
  <div class="bg-surface border border-border-subtle p-8 rounded-xl flex flex-col items-center text-center md:flex-row md:items-center md:text-left md:gap-6">
    <PortraitCarousel class="size-20 mb-4 md:mb-0 shrink-0" />
    <div class="md:flex-1">
      <h4 class="font-bold text-white text-lg mb-2">david multiply</h4>
      <p class="text-sm text-zinc-400 mb-6 md:mb-4 max-w-sm">agency owner and creator. building in public on youtube and writing here.</p>
      <a href="https://www.youtube.com/@davidmultiply" target="_blank" rel="noopener" class="inline-block w-full max-w-[200px] border border-border-subtle text-white py-2.5 rounded-lg text-xs font-bold hover:bg-white hover:text-black transition-all text-center">follow on youtube</a>
    </div>
  </div>
</section>
