<div class="mt-16 py-8 border-y border-border-subtle flex items-center justify-between">
  <div class="flex items-center gap-6">
    <button class="flex items-center gap-2 group transition-colors">
      <span class="material-symbols-outlined text-zinc-400 group-hover:text-primary">favorite</span>
      <span class="text-sm font-medium text-zinc-400 group-hover:text-white">2.4k</span>
    </button>
    <button class="flex items-center gap-2 group transition-colors">
      <span class="material-symbols-outlined text-zinc-400 group-hover:text-primary">bookmark</span>
      <span class="text-sm font-medium text-zinc-400 group-hover:text-white">Save</span>
    </button>
  </div>
  <div class="flex items-center gap-4">
    <span class="text-zinc-500 text-xs font-bold uppercase tracking-wider">Share</span>
    <button class="text-zinc-400 hover:text-primary transition-colors">
      <span class="material-symbols-outlined">send</span>
    </button>
  </div>
</div>
