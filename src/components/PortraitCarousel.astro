---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["portrait-carousel", className]}>
  <img src="/images/portrait-1.jpg" alt="david as a kid with puppies" class="portrait-carousel__img" />
  <img src="/images/portrait-2.jpg" alt="david at the county fair" class="portrait-carousel__img" />
  <img src="/images/portrait-3.jpg" alt="david on the couch" class="portrait-carousel__img" />
  <img src="/images/portrait-4.jpg" alt="david eating a burger" class="portrait-carousel__img" />
  <img src="/images/portrait-5.jpg" alt="david with friends in a gazebo" class="portrait-carousel__img" />
</div>

<style>
  .portrait-carousel {
    position: relative;
    overflow: hidden;
    border-radius: 9999px;
    filter: grayscale(100%);
  }

  .portrait-carousel__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    animation: carousel-fade 20s infinite;
  }

  .portrait-carousel__img:nth-child(1) { animation-delay: 0s; }
  .portrait-carousel__img:nth-child(2) { animation-delay: 4s; }
  .portrait-carousel__img:nth-child(3) { animation-delay: 8s; }
  .portrait-carousel__img:nth-child(4) { animation-delay: 12s; }
  .portrait-carousel__img:nth-child(5) { animation-delay: 16s; }

  /* 5 images × 4s each = 20s cycle. fade in 1s, hold 3s, fade out 1s, hidden 15s */
  @keyframes carousel-fade {
    0% { opacity: 0; }
    5% { opacity: 1; }
    20% { opacity: 1; }
    25% { opacity: 0; }
    100% { opacity: 0; }
  }
</style>
