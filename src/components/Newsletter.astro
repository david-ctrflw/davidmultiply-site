---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
}

const {
  title = "the newsletter",
  description = "occasional notes on building, creating, and running an agency.",
  buttonText = "subscribe"
} = Astro.props;
---

<section id="newsletter" class="py-20 border-t border-border">
  <div class="bg-surface p-10 rounded-2xl border border-border text-center md:flex md:items-center md:text-left md:gap-10 md:p-12">
    <div class="md:flex-1">
      <h3 class="text-2xl font-bold mb-3">{title}</h3>
      <p class="text-zinc-400 text-sm mb-8 max-w-xs mx-auto md:mx-0 md:mb-0 md:max-w-sm">{description}</p>
    </div>
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/mendoza"
      method="post"
      target="popupwindow"
      class="flex flex-col gap-3 max-w-xs mx-auto md:mx-0 md:w-80 md:shrink-0"
    >
      <input
        type="email"
        name="email"
        required
        class="w-full bg-bg border border-border rounded-md px-4 py-3 text-sm focus:ring-1 focus:ring-primary focus:border-primary outline-none text-white placeholder:text-zinc-600 transition-all"
        placeholder="Enter your email"
      />
      <button type="submit" class="w-full bg-primary hover:bg-primary-hover py-3 rounded-md text-sm font-bold text-white transition-colors">
        {buttonText}
      </button>
    </form>
  </div>
</section>
