---
interface RelatedPost {
  title: string;
  date: string;
  readTime: string;
  image?: string;
  imageAlt?: string;
  slug: string;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
---

<section class="mt-16">
  <h3 class="text-xs uppercase tracking-widest text-zinc-500 font-bold mb-8">Continue Reading</h3>
  <div class="grid gap-6 md:grid-cols-2">
    {posts.map((post) => (
      <a
        class="group flex items-center gap-4 p-4 rounded-xl border border-transparent hover:border-border-subtle hover:bg-surface transition-all"
        href={`/blog/${post.slug}`}
      >
        <div class="size-20 rounded-lg overflow-hidden shrink-0 bg-border">
          {post.image && (
            <img
              alt={post.imageAlt || post.title}
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all"
              src={post.image}
            />
          )}
        </div>
        <div>
          <h4 class="text-sm font-bold text-white group-hover:text-primary transition-colors">{post.title}</h4>
          <p class="text-xs text-zinc-500 mt-1">{post.date} &bull; {post.readTime}</p>
        </div>
      </a>
    ))}
  </div>
</section>
