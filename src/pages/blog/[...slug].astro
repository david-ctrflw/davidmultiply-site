---
import PostLayout from '../../layouts/PostLayout.astro';
import ArticleActions from '../../components/ArticleActions.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Get related posts (same category, excluding current)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p => p.id !== post.id)
  .sort((a, b) => {
    // Prioritize same category
    const aMatch = a.data.category === post.data.category ? 1 : 0;
    const bMatch = b.data.category === post.data.category ? 1 : 0;
    if (bMatch !== aMatch) return bMatch - aMatch;
    return b.data.publishDate.getTime() - a.data.publishDate.getTime();
  })
  .slice(0, 2);
---

<PostLayout title={`${post.data.title} - david multiply`} description={post.data.description}>
  <main class="max-w-screen-md lg:max-w-3xl mx-auto px-6 py-12">
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-primary bg-primary/10 border border-primary/20 px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase">{post.data.category}</span>
        <span class="text-zinc-500 text-xs">{post.data.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight tracking-tight text-white mb-8">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-3 pb-8 border-b border-border-subtle">
        <img alt="david multiply" class="size-10 rounded-full object-cover grayscale" src="/images/portrait-1.jpg" />
        <div>
          <p class="text-sm font-bold text-white">david multiply</p>
          <p class="text-xs text-zinc-500">{formatDate(post.data.publishDate)}</p>
        </div>
      </div>
    </header>

    {post.data.image && (
      <div class="rounded-xl overflow-hidden mb-12 aspect-[16/9]">
        <img alt={post.data.imageAlt || post.data.title} class="w-full h-full object-cover" src={post.data.image} />
      </div>
    )}

    <article class="prose max-w-none">
      <Content />
    </article>

    <ArticleActions />
    <AuthorCard />

    <RelatedPosts
      posts={relatedPosts.map(p => ({
        title: p.data.title,
        date: formatDate(p.data.publishDate),
        readTime: p.data.readTime,
        image: p.data.image,
        imageAlt: p.data.imageAlt,
        slug: p.id,
      }))}
    />

    <Newsletter
      title="Weekly Agency Insights"
      description="Join 15,000+ founders receiving my private scaling playbooks."
      buttonText="Join the community"
    />
  </main>
</PostLayout>
